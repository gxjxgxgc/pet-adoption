<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petadoption.petadoption.mapper.PetFavoriteMapper">

    <resultMap id="BaseResultMap" type="com.petadoption.petadoption.entity.PetFavorite">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="pet_id" property="petId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByUserIdAndPetId" resultMap="BaseResultMap">
        SELECT * FROM pet_favorite
        WHERE user_id = #{userId} AND pet_id = #{petId}
    </select>

    <select id="countByPetId" resultType="int">
        SELECT COUNT(*) FROM pet_favorite
        WHERE pet_id = #{petId}
    </select>
</mapper>
